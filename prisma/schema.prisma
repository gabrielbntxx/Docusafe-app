// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  password      String?   // Hashed, nullable for OAuth users

  // Subscription
  planType      String    @default("FREE")
  stripeCustomerId String? @unique
  stripeSubscriptionId String? @unique
  subscriptionStatus String? // active, canceled, past_due
  subscriptionEndsAt DateTime?

  // Usage tracking
  documentsCount Int      @default(0)
  storageUsedBytes BigInt @default(0)

  // Settings
  language             String    @default("en")
  folderPin            String?   // 4-digit PIN for folder creation (hashed)
  theme                String    @default("light")
  notificationsEnabled Int       @default(1) // 1 = enabled, 0 = disabled
  aiSortingEnabled     Int       @default(1) // 1 = enabled, 0 = disabled (user preference)

  // Encryption
  encryptionKey        String?   // User's encryption key (encrypted with master key)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  documents     Document[]
  folders       Folder[]
  notifications Notification[]

  @@index([email])
  @@index([stripeCustomerId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Folder {
  id          String   @id @default(cuid())
  name        String
  color       String?  @default("#3B82F6")
  icon        String?  @default("folder")
  isDefault   Int      @default(0)
  userId      String
  parentId    String?
  pin         String?  // Optional 4-digit PIN for this folder (hashed)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent      Folder?   @relation("FolderHierarchy", fields: [parentId], references: [id])
  children    Folder[]  @relation("FolderHierarchy")
  documents   Document[]

  @@index([userId])
  @@index([parentId])
}

model Document {
  id              String   @id @default(cuid())
  userId          String
  folderId        String?

  // File metadata
  originalName    String
  displayName     String
  fileType        String   // pdf, jpg, png, etc.
  mimeType        String
  sizeBytes       BigInt

  // Storage
  storageKey      String   @unique  // S3/R2 object key
  storageUrl      String?  // Optional CDN URL
  thumbnailUrl    String?
  isEncrypted     Int      @default(0) // 1 = encrypted, 0 = not encrypted

  // AI Analysis & Categorization
  aiAnalyzed      Int      @default(0) // 1 = analyzed by AI, 0 = not analyzed
  aiDocumentType  String?  // Type detected by AI (facture, contrat, etc.)
  aiCategory      String?  // Category detected by AI
  aiConfidence    Float?   // AI confidence score
  aiExtractedData String?  // JSON with extracted metadata (date, amount, issuer)
  fileHash        String?  // SHA-256 hash for cache lookup

  // Metadata
  tags            String   @default("")
  description     String?
  uploadedAt      DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  folder          Folder?   @relation(fields: [folderId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([folderId])
  @@index([aiAnalyzed])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // document_uploaded, document_deleted, folder_created, etc.
  title     String
  message   String?
  read      Int      @default(0) // 0 = unread, 1 = read
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
}

// ============================================
// AI DOCUMENT ANALYSIS
// ============================================

// Cache for AI analysis results (avoid re-analyzing same documents)
model DocumentAnalysisCache {
  id            String   @id @default(cuid())
  fileHash      String   @unique // SHA-256 hash of file content

  // Analysis results
  documentType  String   // facture, fiche_de_paie, contrat, etc.
  category      String   // Finances, Emploi, Administratif, etc.
  confidence    Float    // 0-1 confidence score
  suggestedName String?  // Suggested display name
  extractedDate String?  // Date found in document
  extractedAmount String? // Amount found (for invoices)
  extractedIssuer String? // Company/person who issued the document
  rawResponse   String?  // Full AI response (JSON)

  createdAt     DateTime @default(now())

  @@index([fileHash])
}

// Track AI usage per user per month
model AIUsage {
  id        String   @id @default(cuid())
  userId    String
  month     String   // Format: "2024-01" for January 2024
  count     Int      @default(0) // Number of AI analyses this month

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, month])
  @@index([userId])
}

// Document categories for auto-sorting
model DocumentCategory {
  id          String   @id @default(cuid())
  name        String   // Factures, Fiches de paie, etc.
  nameEn      String   // Invoices, Pay slips, etc.
  slug        String   @unique // factures, fiches-de-paie, etc.
  icon        String   @default("file")
  color       String   @default("#3B82F6")
  keywords    String   // Comma-separated keywords for matching

  createdAt   DateTime @default(now())

  @@index([slug])
}
