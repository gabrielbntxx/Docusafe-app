// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  password      String?   // Hashed, nullable for OAuth users
  phone         String?   // International format (e.g. +33612345678), stored only

  // Subscription
  planType      String    @default("FREE")
  stripeCustomerId String? @unique
  stripeSubscriptionId String? @unique
  subscriptionStatus String? // active, canceled, past_due
  subscriptionEndsAt DateTime?

  // Usage tracking
  documentsCount Int      @default(0)
  storageUsedBytes BigInt @default(0)

  // Settings
  language             String    @default("en")
  folderPin            String?   // 4-digit PIN for folder creation (hashed)
  theme                String    @default("light")
  notificationsEnabled Int       @default(1) // 1 = enabled, 0 = disabled
  aiSortingEnabled     Int       @default(1) // 1 = enabled, 0 = disabled (user preference)
  profession           String?   // User's profession for AI personalization (BUSINESS plan)

  // Security
  passwordChangedAt    DateTime? // Tracks password changes to invalidate old JWTs

  // Encryption
  encryptionKey        String?   // User's encryption key (encrypted with master key)

  // Onboarding
  onboardingCompleted  Boolean   @default(false)

  // Legal consent (RGPD + LCEN)
  termsAcceptedAt      DateTime? // Null = not yet accepted, required before dashboard access
  termsVersion         String?   // Version of CGU/Privacy accepted (e.g. "2026-02-21")

  // Email Import
  importEmailId        String?   @unique // Unique ID for import email (e.g., abc123 for user-abc123@import.docusafe.app)

  // Team (Business plan)
  teamOwnerId  String?   // If set, this user is a member of this owner's team
  teamRole     String?   // "owner" | "member" (null = solo user)
  memberColor  String?   // Unique color assigned in team context (hex)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  documents     Document[]
  folders       Folder[]
  notifications Notification[]
  teamOwner     User?     @relation("TeamMembers", fields: [teamOwnerId], references: [id])
  teamMembers   User[]    @relation("TeamMembers")
  teamInvitations TeamInvitation[]

  @@index([email])
  @@index([stripeCustomerId])
  @@index([teamOwnerId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Folder {
  id          String   @id @default(cuid())
  name        String
  color       String?  @default("#3B82F6")
  icon        String?  @default("folder")
  isDefault   Int      @default(0)
  userId      String
  parentId    String?
  pin         String?  // Optional 4-digit PIN for this folder (hashed)
  rules       String?  @default("{}") // JSON string for folder rules (e.g., convertToPdf)
  isPrivate   Int      @default(0) // 1 = visible only to owner (Business team)
  addedById   String?  // ID of the team member who created this folder

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent      Folder?   @relation("FolderHierarchy", fields: [parentId], references: [id])
  children    Folder[]  @relation("FolderHierarchy")
  documents   Document[]

  @@index([userId])
  @@index([parentId])
}

model Document {
  id              String   @id @default(cuid())
  userId          String
  folderId        String?

  // File metadata
  originalName    String
  displayName     String
  fileType        String   // pdf, jpg, png, etc.
  mimeType        String
  sizeBytes       BigInt

  // Storage
  storageKey      String   @unique  // S3/R2 object key
  storageUrl      String?  // Optional CDN URL
  thumbnailUrl    String?
  isEncrypted     Int      @default(0) // 1 = encrypted, 0 = not encrypted

  // AI Analysis & Categorization
  aiAnalyzed      Int      @default(0) // 1 = analyzed by AI, 0 = not analyzed
  aiDocumentType  String?  // Type detected by AI (facture, contrat, etc.)
  aiCategory      String?  // Category detected by AI
  aiConfidence    Float?   // AI confidence score
  aiExtractedData String?  // JSON with extracted metadata (date, amount, issuer)
  fileHash        String?  // SHA-256 hash for cache lookup

  // Metadata
  tags            String   @default("")
  description     String?
  isPrivate       Int      @default(0) // 1 = visible only to owner (Business team)
  addedById       String?  // ID of the team member who uploaded this document
  uploadedAt      DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime? // Soft delete: set on user deletion, null = active doc

  // Expiry tracking
  expiryDate      DateTime? // Expiry/renewal date (AI-detected or set manually)
  expiryNotified  String?   // JSON: thresholds already notified e.g. "[60,30,7]"

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  folder          Folder?   @relation(fields: [folderId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([folderId])
  @@index([aiAnalyzed])
  @@index([deletedAt])
  @@index([expiryDate])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // document_uploaded, document_deleted, folder_created, etc.
  title     String
  message   String?
  read      Int      @default(0) // 0 = unread, 1 = read
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
}

// ============================================
// AI DOCUMENT ANALYSIS
// ============================================

// Cache for AI analysis results (avoid re-analyzing same documents)
model DocumentAnalysisCache {
  id            String   @id @default(cuid())
  fileHash      String   @unique // SHA-256 hash of file content

  // Analysis results
  documentType  String   // facture, fiche_de_paie, contrat, etc.
  category      String   // Finances, Emploi, Administratif, etc.
  confidence    Float    // 0-1 confidence score
  suggestedName String?  // Suggested display name
  extractedDate String?  // Date found in document
  extractedAmount String? // Amount found (for invoices)
  extractedIssuer String? // Company/person who issued the document
  rawResponse   String?  // Full AI response (JSON)

  createdAt     DateTime @default(now())

  @@index([fileHash])
}

// Track AI usage per user per month
model AIUsage {
  id        String   @id @default(cuid())
  userId    String
  month     String   // Format: "2024-01" for January 2024
  count     Int      @default(0) // Number of AI analyses this month

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, month])
  @@index([userId])
}

// Document categories for auto-sorting
model DocumentCategory {
  id          String   @id @default(cuid())
  name        String   // Factures, Fiches de paie, etc.
  nameEn      String   // Invoices, Pay slips, etc.
  slug        String   @unique // factures, fiches-de-paie, etc.
  icon        String   @default("file")
  color       String   @default("#3B82F6")
  keywords    String   // Comma-separated keywords for matching

  createdAt   DateTime @default(now())

  @@index([slug])
}

// Password reset tokens
model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
  @@index([token])
}

// Email verification tokens
model EmailVerificationToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique // SHA-256 hash of 6-digit code
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
  @@index([token])
}

// ============================================
// SHARING
// ============================================

// Share link for sharing folders/documents
model SharedLink {
  id            String   @id @default(cuid())
  userId        String   // Owner of the share
  token         String   @unique // Unique share token for URL
  name          String?  // Optional name for the share

  // Security
  password      String?  // Optional password (hashed)
  expiresAt     DateTime // Expiration date

  // Stats
  viewCount     Int      @default(0)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  items         SharedItem[]

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}

// Items included in a share (folders or documents)
model SharedItem {
  id            String   @id @default(cuid())
  sharedLinkId  String
  folderId      String?  // If sharing a folder
  documentId    String?  // If sharing a document

  createdAt     DateTime @default(now())

  sharedLink    SharedLink @relation(fields: [sharedLinkId], references: [id], onDelete: Cascade)

  @@index([sharedLinkId])
  @@index([folderId])
  @@index([documentId])
}

// ============================================
// DOCUMENT REQUESTS
// ============================================

// Request for documents from external users
model DocumentRequest {
  id            String   @id @default(cuid())
  userId        String   // Owner who created the request
  token         String   @unique // Unique token for the request URL

  // Request details
  title         String   // Title of the request
  description   String?  // Description/instructions
  recipientName String?  // Name of the person/company
  recipientEmail String? // Email to notify

  // Security
  password      String?  // Optional password (hashed)
  expiresAt     DateTime // Expiration date
  maxFiles      Int      @default(5) // Max files allowed
  maxFileSize   Int      @default(1024) // Max file size in MB (1GB)

  // Status
  status        String   @default("pending") // pending, completed, expired
  filesReceived Int      @default(0)

  // Stats
  viewCount     Int      @default(0)
  lastViewedAt  DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  uploads       RequestUpload[]

  @@index([userId])
  @@index([token])
  @@index([status])
  @@index([expiresAt])
}

// Files uploaded to a request
model RequestUpload {
  id            String   @id @default(cuid())
  requestId     String
  documentId    String?  // Link to Document if saved

  // File info
  originalName  String
  fileType      String
  mimeType      String
  sizeBytes     BigInt
  storageKey    String   // S3/R2 key

  // Metadata
  uploaderName  String?  // Name provided by uploader
  uploaderEmail String?  // Email provided by uploader
  note          String?  // Note from uploader

  createdAt     DateTime @default(now())

  request       DocumentRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
}

// ============================================
// TEAM (Business plan)
// ============================================

model TeamInvitation {
  id          String   @id @default(cuid())
  ownerId     String   // The team owner who sent the invite
  email       String   // Email of the invitee
  token       String   @unique // Unique token for the invitation link
  status      String   @default("pending") // pending, accepted, expired, revoked
  role        String   @default("editeur") // owner | admin | editeur | lecteur

  createdAt   DateTime @default(now())
  expiresAt   DateTime // Expires after 7 days

  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([ownerId])
  @@index([email])
}
